{
  "name": "hakol-besefer",
  "private": true,
  "version": "0.1.0",
  "description": "Clean rebuild foundation for Hakol BeSefer",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:lab": "vite --mode lab",
    "dev:prod": "vite --mode production",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "smoke:contracts": "node scripts/smoke_contracts.mjs",
    "check": "npm run smoke:contracts && npm run build"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.93.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "^5.8.2",
    "vite": "^6.2.0"
  }
}
